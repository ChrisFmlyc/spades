#!/usr/bin/env bash
set -euo pipefail

# SPADE Framework — Setup Script
# Installs SPADE into a target project repository.
#
# Usage:
#   ./setup                     # Interactive: prompts for target directory
#   ./setup /path/to/project    # Direct: installs into specified project
#   ./setup --global            # Installs skills to ~/.claude/skills/ for all projects
#   ./setup --upgrade /path     # Upgrade existing installation
#   ./setup --remove /path      # Remove SPADE sections from a project
#
# How it handles existing files:
#   - CLAUDE.md / AGENTS.md: If they already exist, SPADE sections are injected
#     between marker comments. Existing content outside the markers is preserved.
#     On upgrade, only the content between markers is replaced.
#   - ARCHITECTURE.md / PATTERNS.md / ANTI-PATTERNS.md: Created as templates
#     only if they don't exist. Never touched on upgrade.
#   - .claude/skills/spade-*: Always overwritten (framework-owned).

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="1.0.0"

# Marker comments used to identify SPADE sections in existing files
MARKER_START="<!-- SPADE-FRAMEWORK-START v${VERSION} -->"
MARKER_START_PATTERN="<!-- SPADE-FRAMEWORK-START"
MARKER_END="<!-- SPADE-FRAMEWORK-END -->"

# Colours for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_header() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  SPADE Framework v${VERSION}${NC}"
    echo -e "${BLUE}  A Human-AI Operating Model for Engineering Teams${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

print_success() { echo -e "${GREEN}✓${NC} $1"; }
print_warning() { echo -e "${YELLOW}!${NC} $1"; }
print_info()    { echo -e "${BLUE}→${NC} $1"; }
print_error()   { echo -e "${RED}✗${NC} $1"; }

has_spade_section() {
    grep -q "$MARKER_START_PATTERN" "$1" 2>/dev/null
}

# Inject or replace a SPADE section in an existing file.
inject_section() {
    local source_file="$1"
    local target_file="$2"
    local label="$3"

    local section_content
    section_content=$(cat "$source_file")

    local marked_content
    marked_content=$(printf '%s\n%s\n%s' "$MARKER_START" "$section_content" "$MARKER_END")

    if [[ ! -f "$target_file" ]]; then
        echo "$marked_content" > "$target_file"
        print_success "$label created (new file)"
    elif has_spade_section "$target_file"; then
        local tmpfile
        tmpfile=$(mktemp)
        local marker_pat="$MARKER_START_PATTERN"

        awk -v start_pat="$marker_pat" -v end="$MARKER_END" -v replacement="$marked_content" '
            BEGIN { skip=0; replaced=0 }
            index($0, start_pat) == 1 { skip=1; next }
            skip && $0 == end {
                skip=0
                if (!replaced) { print replacement; replaced=1 }
                next
            }
            !skip { print }
        ' "$target_file" > "$tmpfile"

        mv "$tmpfile" "$target_file"
        print_success "$label updated (SPADE section replaced, your content preserved)"
    else
        {
            echo ""
            echo "$marked_content"
        } >> "$target_file"
        print_success "$label augmented (SPADE section appended to existing file)"
    fi
}

remove_section() {
    local target_file="$1"
    local label="$2"

    if [[ ! -f "$target_file" ]]; then
        return
    fi

    if ! has_spade_section "$target_file"; then
        print_warning "$label has no SPADE section, skipping"
        return
    fi

    local tmpfile
    tmpfile=$(mktemp)
    local marker_pat="$MARKER_START_PATTERN"

    awk -v start_pat="$marker_pat" -v end="$MARKER_END" '
        index($0, start_pat) == 1 { skip=1; next }
        $0 == end { skip=0; next }
        !skip { print }
    ' "$target_file" > "$tmpfile"

    if [[ ! -s "$tmpfile" ]] || [[ -z "$(tr -d '[:space:]' < "$tmpfile")" ]]; then
        rm "$target_file" "$tmpfile"
        print_success "$label removed (file was SPADE-only)"
    else
        mv "$tmpfile" "$target_file"
        print_success "$label cleaned (SPADE section removed, your content preserved)"
    fi
}

copy_if_missing() {
    local src="$1"
    local dest="$2"
    local label="$3"

    if [[ -f "$dest" ]]; then
        print_warning "$label already exists, skipping (won't overwrite)"
    else
        cp "$src" "$dest"
        print_success "$label created"
    fi
}

copy_always() {
    local src="$1"
    local dest="$2"
    local label="$3"
    cp "$src" "$dest"
    print_success "$label installed"
}

install_to_project() {
    local target="$1"

    if [[ ! -d "$target" ]]; then
        print_error "Directory does not exist: $target"
        exit 1
    fi

    echo "Installing SPADE into: $target"
    echo ""

    # AGENTS.md and CLAUDE.md: inject or augment
    echo "Configuring framework files..."
    inject_section "$SCRIPT_DIR/fragments/AGENTS-section.md" "$target/AGENTS.md" "AGENTS.md"
    inject_section "$SCRIPT_DIR/fragments/CLAUDE-section.md" "$target/CLAUDE.md" "CLAUDE.md"

    echo ""

    # Skills: always overwrite
    echo "Installing skills..."
    mkdir -p "$target/.claude/skills"
    for skill_dir in "$SCRIPT_DIR/.claude/skills"/*/; do
        skill_name="$(basename "$skill_dir")"
        mkdir -p "$target/.claude/skills/$skill_name"
        copy_always "$skill_dir/SKILL.md" "$target/.claude/skills/$skill_name/SKILL.md" "Skill: $skill_name"
    done

    echo ""

    # Architecture templates: never overwrite
    echo "Setting up architecture templates..."
    copy_if_missing "$SCRIPT_DIR/ARCHITECTURE.md" "$target/ARCHITECTURE.md" "ARCHITECTURE.md"
    copy_if_missing "$SCRIPT_DIR/PATTERNS.md" "$target/PATTERNS.md" "PATTERNS.md"
    copy_if_missing "$SCRIPT_DIR/ANTI-PATTERNS.md" "$target/ANTI-PATTERNS.md" "ANTI-PATTERNS.md"

    # Examples and docs
    if [[ ! -d "$target/.spade/examples" ]]; then
        mkdir -p "$target/.spade/examples"
        cp "$SCRIPT_DIR/examples/"*.md "$target/.spade/examples/" 2>/dev/null || true
        print_success "Example templates installed to .spade/examples/"
    else
        print_warning ".spade/examples/ already exists, skipping"
    fi

    mkdir -p "$target/.spade/docs"
    cp "$SCRIPT_DIR/docs/"*.md "$target/.spade/docs/" 2>/dev/null || true

    # Version metadata
    mkdir -p "$target/.spade"
    cat > "$target/.spade/version" <<EOF
spade_version=$VERSION
installed_at=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
source=$SCRIPT_DIR
EOF
    print_success "Version metadata recorded"

    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  SPADE installed successfully.${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Next steps:"
    echo ""
    echo "  1. Run /spade-onboard in Claude Code to fill in architecture docs"
    echo "  2. Start using SPADE: /spade-scope, /spade-plan, /spade-approve"
    echo "  3. See examples in .spade/examples/"
    echo ""
}

install_global() {
    local skills_dir="$HOME/.claude/skills"
    echo "Installing SPADE skills globally to $skills_dir"
    echo ""
    mkdir -p "$skills_dir"
    for skill_dir in "$SCRIPT_DIR/.claude/skills"/*/; do
        skill_name="$(basename "$skill_dir")"
        mkdir -p "$skills_dir/$skill_name"
        copy_always "$skill_dir/SKILL.md" "$skills_dir/$skill_name/SKILL.md" "Skill: $skill_name"
    done
    echo ""
    print_success "Global skills installed."
    print_info "AGENTS.md and architecture docs must still be installed per-project."
    echo ""
}

remove_from_project() {
    local target="$1"
    if [[ ! -f "$target/.spade/version" ]]; then
        print_error "No SPADE installation found in $target"
        exit 1
    fi
    echo "Removing SPADE from: $target"
    echo ""
    remove_section "$target/AGENTS.md" "AGENTS.md"
    remove_section "$target/CLAUDE.md" "CLAUDE.md"
    for skill_dir in "$target/.claude/skills"/spade-*/; do
        [[ -d "$skill_dir" ]] && rm -rf "$skill_dir" && print_success "Removed skill: $(basename "$skill_dir")"
    done
    [[ -d "$target/.spade" ]] && rm -rf "$target/.spade" && print_success "Removed .spade/ directory"
    print_warning "ARCHITECTURE.md, PATTERNS.md, ANTI-PATTERNS.md preserved (contain your content)"
    echo ""
    print_success "SPADE removed. Your existing file content is intact."
    echo ""
}

# Main
print_header

case "${1:-}" in
    --global)   install_global ;;
    --upgrade)
        [[ -z "${2:-}" ]] && print_error "Usage: ./setup --upgrade /path" && exit 1
        install_to_project "$(cd "$2" && pwd)"
        ;;
    --remove)
        [[ -z "${2:-}" ]] && print_error "Usage: ./setup --remove /path" && exit 1
        remove_from_project "$(cd "$2" && pwd)"
        ;;
    --help|-h)
        echo "Usage:"
        echo "  ./setup                     Interactive install"
        echo "  ./setup /path/to/project    Install into specific project"
        echo "  ./setup --global            Install skills globally"
        echo "  ./setup --upgrade /path     Upgrade existing installation"
        echo "  ./setup --remove /path      Remove SPADE from a project"
        echo "  ./setup --help              Show this help"
        echo ""
        echo "Existing files:"
        echo "  CLAUDE.md / AGENTS.md → SPADE sections injected between markers"
        echo "  Architecture docs     → Created only if missing, never overwritten"
        echo "  Skills                → Always updated to latest version"
        echo ""
        ;;
    "")
        echo "Where would you like to install SPADE?"
        read -rp "Project path (or '.' for current directory): " target_path
        target_path="${target_path:-.}"
        install_to_project "$(cd "$target_path" && pwd)"
        ;;
    *)
        install_to_project "$(cd "$1" && pwd)"
        ;;
esac
