#!/usr/bin/env bash
set -euo pipefail

# SPADE Framework — Setup Script
# Installs SPADE skills globally for all Claude Code sessions.
#
# Usage:
#   ./setup              # Install skills globally to ~/.claude/skills/
#   ./setup --help       # Show help
#
# After running this, use /spade-onboard in any project to initialise
# SPADE files and fill in architecture docs.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="1.6.0"

# Colours for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_header() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  SPADE Framework v${VERSION}${NC}"
    echo -e "${BLUE}  A Human-AI Operating Model for Engineering Teams${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

print_success() { echo -e "${GREEN}✓${NC} $1"; }
print_warning() { echo -e "${YELLOW}!${NC} $1"; }
print_info()    { echo -e "${BLUE}→${NC} $1"; }
print_error()   { echo -e "${RED}✗${NC} $1"; }

copy_always() {
    local src="$1"
    local dest="$2"
    local label="$3"
    cp "$src" "$dest"
    print_success "$label installed"
}

install_global() {
    local skills_dir="$HOME/.claude/skills"
    echo "Installing SPADE skills globally to $skills_dir"
    echo ""
    mkdir -p "$skills_dir"
    for skill_dir in "$SCRIPT_DIR/.claude/skills"/*/; do
        skill_name="$(basename "$skill_dir")"
        mkdir -p "$skills_dir/$skill_name"
        copy_always "$skill_dir/SKILL.md" "$skills_dir/$skill_name/SKILL.md" "Skill: $skill_name"
    done
    echo ""
    print_success "Global skills installed."
    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  SPADE installed successfully.${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Next steps:"
    echo ""
    echo "  1. Open Claude Code in any project"
    echo "  2. Run /spade-onboard to initialise SPADE and fill in architecture docs"
    echo "  3. Commit the generated files so your team gets SPADE automatically"
    echo ""
}

# Main
print_header

case "${1:-}" in
    --help|-h)
        echo "Usage:"
        echo "  ./setup          Install SPADE skills globally (~/.claude/skills/)"
        echo "  ./setup --help   Show this help"
        echo ""
        echo "After installing, run /spade-onboard in Claude Code within any"
        echo "project to initialise SPADE files and fill in architecture docs."
        echo ""
        ;;
    "")
        install_global
        ;;
    *)
        print_error "Unknown option: $1"
        echo "Run ./setup --help for usage."
        exit 1
        ;;
esac
