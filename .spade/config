# SPADE per-repo configuration.
# Read by SPADE skills to avoid prompting for team/project on every invocation.

# Operating mode: linear | local | hybrid. An explicit value always wins
# over auto-detect. See docs/FRAMEWORK.md § Operating Modes.
mode: linear

linear:
  team: M-KOPA
  team_id: 55069140-fef8-4f1a-8d04-726227e0292b
  project: SPADE
  project_id: 576ca5be-0c4a-4a88-b10b-8fd1501a6f82
  project_url: https://linear.app/m-kopa/project/spade-dd39ae1b0c87
  default_assignee: me

# Notes:
# - This repo is the SPADE framework itself. The loop governs its own work.
# - Parent Linear issues are Scopes; sub-issues are Plan tasks.
# - Plans are persisted locally under .spade/plans/ in addition to Linear comments.

# Handoff configuration (opt-in) — consumed by /spade-handoff to spawn a
# fresh CLI agent in a new terminal window to deliver an approved Plan.
# When this block is absent, /spade-handoff is dormant. Terminal choice is
# machine-specific and lives in the gitignored .spade/handoff.local.
handoff:
  agent: claude            # which agent to spawn: claude | amp
  autonomous: false        # false = spawned agent runs interactively;
                           # true  = add the agent's skip-permission flag
                           #         and confirm on every run
  agents:
    claude:
      command: ["claude", "--permission-mode", "acceptEdits"]
      prompt_via: arg
      autonomous_flag: "--dangerously-skip-permissions"
    amp:
      command: ["amp"]
      prompt_via: stdin
      autonomous_flag: "--dangerously-allow-all"
